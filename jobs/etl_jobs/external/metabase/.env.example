# Metabase Migration Tool - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# Load with: source .env (or direnv, or export $(cat .env | xargs))

export PROJECT_NAME=passculture-data-ehp
export ENV_SHORT_NAME=stg

# Port-forward bypass (kubectl -n metabase-analytics port-forward svc/metabase-analytics 8082:80)
export METABASE_HOST=http://localhost:8082

# Optional: Override password if Secret Manager is unavailable
# export METABASE_PASSWORD=your-password-here

# Database name in Metabase (required for stg_explore.py and migration commands)
export DATABASE_NAME="Data Analytics Staging"
